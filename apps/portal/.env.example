############################################################
# @ugur/portal env example
#
# Copy to apps/portal/.env for local portal runtime.
############################################################

# Core backend
MONGODB_URI=
ADMIN_API_KEY=
APP_URL=http://localhost:3001

# Optional auth tuning
ADMIN_SESSION_TTL_SECONDS=86400
ADMIN_INVITE_EXPIRES_HOURS=72

# Optional preview/screenshot pipeline
# none | r2
PREVIEW_USE_STORAGE=none
SCREENSHOT_PROVIDER_URL=
SCREENSHOT_API_KEY=

# Required only when PREVIEW_USE_STORAGE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_FORCE_PATH_STYLE=true
R2_PUBLIC_BASE_URL=
