############################################################
# @ugur/site env example
#
# Copy to apps/site/.env for local site runtime.
# Safe defaults are included where possible.
############################################################

# Public canonical site URL (used for sitemap/absolute links).
# Optional in local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# For static export (output: "export"): URL for contact form submissions.
# Omit when running as Web Service (form uses same-origin /api/contact).
# NEXT_PUBLIC_CONTACT_API_URL=https://your-backend.com/api/contact

# Optional DB source for dynamic content.
# If empty, site falls back to MDX/content files.
MONGODB_URI=

# Optional on-demand revalidation secret (if using revalidate endpoint/workflows).
REVALIDATE_SECRET=
