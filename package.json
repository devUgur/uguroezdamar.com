{
  "name": "uguroezdamar.com",
  "version": "1.0.0",
  "description": "The official website of Ugur Özdamar",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "turbo dev",
    "guard:legacy-imports": "node ./tooling/guards/legacy-imports.mjs",
    "guard:no-feature-server-imports": "node ./tooling/guards/no-feature-server-imports.mjs",
    "guard:no-deep-imports": "node ./tooling/guards/no-deep-imports.mjs",
    "guard:no-next-in-server": "node ./tooling/guards/no-next-in-server.mjs",
    "guard": "pnpm guard:legacy-imports && pnpm guard:no-feature-server-imports && pnpm guard:no-deep-imports && pnpm guard:no-next-in-server",
    "check:no-legacy-ui": "pnpm guard:legacy-imports",
    "build": "pnpm guard && turbo build",
    "build:site": "pnpm guard && turbo run build --filter=@ugur/site",
    "lint": "pnpm guard && turbo lint",
    "typecheck": "pnpm guard && turbo typecheck",
    "test": "pnpm guard && turbo run build --filter=@ugur/server --filter=@ugur/core && vitest run",
    "clean": "turbo clean",
    "setup:indexes": "node ./tooling/scripts/setup-indexes.mjs",
    "migrate:projects": "node ./tooling/scripts/migrate-projects.mjs",
    "ui:add": "pnpm dlx shadcn@latest add -c packages/ui",
    "ui:diff": "pnpm dlx shadcn@latest diff -c packages/ui",
    "start": "pnpm --filter @ugur/site start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devUgur/uguroezdamar.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/devUgur/uguroezdamar.com/issues"
  },
  "homepage": "https://github.com/devUgur/uguroezdamar.com#readme",
  "dependencies": {
    "@ugur/ui": "workspace:*",
    "@aws-sdk/client-s3": "^3.1000.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "mongodb": "^5.9.2",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "turbo": "^2.5.8",
    "vitest": "^1.0.0"
  }
}
