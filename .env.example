############################################################
# Workspace-level env example (tooling + shared defaults)
#
# For app runtime config, use:
# - apps/site/.env.example
# - apps/portal/.env.example
#
# Copy this file to `.env` only if you need shared values for
# root scripts/tests (tooling/scripts, tests/*).
############################################################

# Required for DB tooling scripts and integration tests.
MONGODB_URI=

# Required for admin bootstrap/login helper flows.
ADMIN_API_KEY=

# Optional secret used by revalidation script/endpoint integrations.
REVALIDATE_SECRET=

# Optional TTL index setup for leads collection (days).
# Empty = no TTL index.
LEADS_RETENTION_DAYS=
