##############################################
# Environment variables example (.env.example)
#
# Copy this file to `.env` for local development or set the values
# in your hosting provider (Netlify / Vercel / etc). DO NOT commit
# real secrets to source control.
##############################################

# Static admin API key (used by admin endpoints)
# Example header: Authorization: Bearer <ADMIN_API_KEY>
# Purpose: authenticates humans/tools that read leads. Keep secret and rotate.
ADMIN_API_KEY=

# Secret for ISR revalidation endpoint (/api/revalidate)
# Purpose: called by server-to-server workflows to trigger Next.js revalidation.
# This key is NOT used for admin API access — keep it separate for safer rotation.
REVALIDATE_SECRET=

# MongoDB connection URI (server-only)
MONGODB_URI=

# Optional: retention in days for leads (used by setup-indexes script to create a TTL index)
# Leave empty to disable automatic TTL index creation. Example: 180
LEADS_RETENTION_DAYS=
